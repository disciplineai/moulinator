{
  "name": "@moulinator/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm gen:api",
    "dev": "next dev -p 3000",
    "prebuild": "pnpm gen:api",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "pretypecheck": "pnpm gen:api",
    "typecheck": "tsc --noEmit",
    "gen:api": "openapi-typescript ../../openapi.yaml -o src/api/generated/schema.d.ts"
  },
  "dependencies": {
    "next": "14.2.13",
    "openapi-fetch": "^0.13.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.13",
    "openapi-typescript": "^7.4.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.4.5"
  }
}
